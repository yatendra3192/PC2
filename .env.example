# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/pc2
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=your-service-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Redis
REDIS_URL=redis://localhost:6379

# ── AI Model Keys ──
# Set these to enable real AI processing (instead of demo/mock mode)

# OpenAI (GPT-4o for LLM, Vision, Embeddings)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (Claude — optional fallback for LLM tasks)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Cloud (optional — for OCR and Vision)
GOOGLE_VISION_API_KEY=
GOOGLE_DOCUMENT_AI_KEY=

# ── Web Scraping ──
SERPAPI_KEY=your-serpapi-key
SCRAPER_PROXY_URL=

# ── External Integrations ──
# Athena DQ
ATHENA_DQ_URL=https://dq.iksula.com/api/v2
ATHENA_DQ_API_KEY=your-dq-key

# PIM
SITEONE_PIM_URL=https://pim.siteone.com/api
SITEONE_PIM_KEY=your-pim-key
THD_PIM_URL=https://pim.homedepot.com/api
THD_PIM_KEY=your-pim-key

# ── App ──
# Set DEMO_MODE=false to use real AI models (requires API keys above)
# Set DEMO_MODE=true to use hardcoded demo data (no API keys needed)
DEMO_MODE=false
SECRET_KEY=change-this-to-a-random-string
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
